# ─────────────────────────────────────────────────────────────
# Portfolio Tracker — environment variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ───────────────────────────
# DATABASE_URL: pooled connection (PgBouncer, IPv4-compatible) used by the
#   app at runtime via @prisma/adapter-pg.
# DIRECT_URL:   direct connection used by Prisma Migrate (see prisma.config.ts).
#   Migrations must use the direct connection, NOT the pooler.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# ── Supabase Auth (client-side) ──────────────────────────────
# Public values, safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Encryption ───────────────────────────────────────────────
# AES-256-GCM key for encrypting sensitive values stored in the DB
# (e.g. Gmail refresh tokens). Must be a 64-character hex string (32 bytes).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-key"

# ── EODHD Market Data API ────────────────────────────────────
# Fallback price source. Users can also store their own key in Settings.
EODHD_API_KEY="your-eodhd-api-key"

# ── Gmail OAuth (transaction import) ─────────────────────────
# OAuth 2.0 credentials for the MyInvestor email import flow (readonly scope).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match the redirect URI registered in Google Cloud Console.
# Local default: http://localhost:3000/api/auth/gmail/callback
GOOGLE_REDIRECT_URI=""

# ── Vercel Cron ──────────────────────────────────────────────
# Shared secret protecting the daily price-update cron endpoint
# (GET|POST /api/cron/update-prices).
CRON_SECRET="your-cron-secret"
