// Portfolio Tracker Database Schema
// Using PostgreSQL (Supabase) with Prisma ORM
// Multi-tenant: Each user has isolated data
//
// Three isolated domains, never cross-referencing each other:
//   1. Wallet      → CashMovement (cash deposits/withdrawals)
//   2. Investments → Asset / InvestmentTransaction / Holding / Price (+ import pipeline)
//   3. Real estate → Property / Mortgage / valuations
// Aggregation across domains happens only at read time (dashboard service),
// never in the data model.

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Domain 1: Wallet (cash)
// ─────────────────────────────────────────────────────────────

enum CashMovementType {
  DEPOSIT
  WITHDRAWAL
}

// A single cash entry or exit. `amount` is always positive; the sign is
// derived from `type`. The wallet balance is the running sum of movements.
model CashMovement {
  id     String           @id @default(cuid())
  userId String // Supabase auth user ID
  type   CashMovementType
  date   DateTime
  amount Decimal          @db.Decimal(18, 4)
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}

// ─────────────────────────────────────────────────────────────
// Domain 2: Investments (real, market-traded assets)
// ─────────────────────────────────────────────────────────────

// Asset classes — real financial instruments only. Cash lives in Wallet.
enum AssetClass {
  FUND // index / mutual funds
  ETF
  STOCK
  PENSION // pension plans (planes de pensiones)
}

// Investment transaction types. Transfers are flattened into IN/OUT so the
// type alone fully describes the effect on the position.
enum TransactionType {
  BUY
  SELL
  TRANSFER_IN
  TRANSFER_OUT
  DIVIDEND
  FEE
}

// Price Data Source
enum PriceSource {
  EODHD
  MANUAL
}

// Import Source
enum ImportSource {
  GMAIL
  MANUAL
}

// Import Status
enum ImportStatus {
  PENDING
  PREVIEWING
  IMPORTING
  COMPLETED
  FAILED
}

// Core Asset Model (user-specific)
model Asset {
  id            String     @id @default(cuid())
  userId        String // Supabase auth user ID
  isin          String
  ticker        String?
  name          String
  category      AssetClass @default(FUND)
  currency      String     @default("EUR")
  isActive      Boolean    @default(true)
  // Assets without a market data feed are valued at cost basis.
  manualPricing Boolean    @default(false)

  transactions Transaction[]
  prices       Price[]
  holding      Holding?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ISIN unique per user (same asset can exist for different users)
  @@unique([userId, isin])
  // Ticker unique per user
  @@unique([userId, ticker])
  @@index([userId])
  @@index([category])
  @@index([isActive])
}

// Investment Transaction Model (user-specific)
model Transaction {
  id      String      @id @default(cuid())
  userId  String // Supabase auth user ID (for direct queries)
  assetId String
  asset   Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)

  type          TransactionType
  date          DateTime
  shares        Decimal         @db.Decimal(18, 8)
  pricePerShare Decimal?        @db.Decimal(18, 8)
  totalAmount   Decimal         @db.Decimal(18, 4)
  fees          Decimal?        @default(0) @db.Decimal(18, 4)

  importBatchId  String?
  importBatch    ImportBatch? @relation(fields: [importBatchId], references: [id])
  sourceHash     String?
  gmailMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Gmail message ID unique per user (same email imported by different users is OK)
  @@unique([userId, gmailMessageId])
  @@index([userId])
  @@index([assetId])
  @@index([date])
  @@index([type])
  @@index([importBatchId])
  // Composite index for FIFO calculations (asset + date ordering)
  @@index([assetId, date])
}

// Holding Model (user-specific, calculated from transactions)
model Holding {
  id      String @id @default(cuid())
  userId  String // Supabase auth user ID
  assetId String @unique
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  shares         Decimal  @db.Decimal(18, 8)
  costBasis      Decimal  @db.Decimal(18, 4)
  avgPrice       Decimal  @db.Decimal(18, 8)
  marketValue    Decimal? @db.Decimal(18, 4)
  unrealizedGain Decimal? @db.Decimal(18, 4)

  lastCalculatedAt DateTime @default(now())

  @@index([userId])
  @@index([shares])
}

// Historical Price Data (shared globally - prices are same for everyone)
model Price {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  date   DateTime    @db.Date
  open   Decimal?    @db.Decimal(18, 8)
  high   Decimal?    @db.Decimal(18, 8)
  low    Decimal?    @db.Decimal(18, 8)
  close  Decimal     @db.Decimal(18, 8)
  volume BigInt?
  source PriceSource @default(EODHD)

  @@unique([assetId, date])
  @@index([date])
  // Composite index for latest price queries (asset + date desc)
  @@index([assetId, date(sort: Desc)])
}

// Price Cache for Quick Lookups (shared globally)
model PriceCache {
  id          String   @id @default(cuid())
  ticker      String   @unique
  latestPrice Decimal  @db.Decimal(18, 8)
  priceDate   DateTime @db.Date
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

// Import Batch for Gmail Import (user-specific)
model ImportBatch {
  id     String       @id @default(cuid())
  userId String // Supabase auth user ID
  source ImportSource
  status ImportStatus @default(PENDING)

  gmailQuery      String?
  oldestEmailDate DateTime?
  newestEmailDate DateTime?

  totalRows    Int   @default(0)
  importedRows Int   @default(0)
  skippedRows  Int   @default(0)
  errors       Json?
  preview      Json?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// Ticker Mapping (shared globally - reference data)
model TickerMapping {
  id          String     @id @default(cuid())
  isin        String     @unique
  ticker      String
  displayName String
  category    AssetClass

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticker])
}

// ─────────────────────────────────────────────────────────────
// Domain 3: Real estate
// ─────────────────────────────────────────────────────────────

// Mortgage interest type
enum MortgageType {
  FIXED
  VARIABLE
}

// Effect of a partial (early) amortization on the loan
enum AmortizationMode {
  REDUCE_TERM
  REDUCE_INSTALLMENT
}

// Real Estate Property (user-specific)
model Property {
  id           String   @id @default(cuid())
  userId       String // Supabase auth user ID
  name         String
  purchaseDate DateTime
  currency     String   @default("EUR")
  // Base price (excluding taxes) and the rates applied on top of it
  purchasePrice   Decimal @default(0) @db.Decimal(18, 4)
  vatRate         Decimal @default(0.10) @db.Decimal(9, 6)
  transferTaxRate Decimal @default(0.015) @db.Decimal(9, 6)
  purchaseCosts   Decimal @default(0) @db.Decimal(18, 4)

  owners     PropertyOwner[]
  valuations PropertyValuation[]
  mortgage   Mortgage?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Ownership split for a property
model PropertyOwner {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  sharePct   Decimal  @db.Decimal(9, 4) // e.g. 50.0000
  isSelf     Boolean  @default(false) // marks the owner that represents the app user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
}

// Manual market value snapshot for a property
model PropertyValuation {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  value      Decimal  @db.Decimal(18, 4)
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, date])
  @@index([userId])
  @@index([propertyId])
}

// Mortgage attached to a property (one per property)
model Mortgage {
  id                 String       @id @default(cuid())
  userId             String
  propertyId         String       @unique
  property           Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  loanAmount         Decimal      @db.Decimal(18, 4)
  downPayment        Decimal      @db.Decimal(18, 4)
  termMonths         Int
  annualInterestRate Decimal      @db.Decimal(9, 6)
  type               MortgageType @default(FIXED)
  startDate          DateTime // date of the first regular payment
  // Optional interest-only "stub" payment before the regular schedule begins,
  // covering the broken period between disbursement and the first installment.
  initialInterestAmount Decimal?  @db.Decimal(18, 4)
  initialInterestDate   DateTime?

  partialAmortizations PartialAmortization[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Partial (early) repayment against a mortgage
model PartialAmortization {
  id         String           @id @default(cuid())
  userId     String
  mortgageId String
  mortgage   Mortgage         @relation(fields: [mortgageId], references: [id], onDelete: Cascade)
  date       DateTime
  amount     Decimal          @db.Decimal(18, 4)
  mode       AmortizationMode @default(REDUCE_TERM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mortgageId])
}

// ─────────────────────────────────────────────────────────────
// Cross-cutting: Settings
// ─────────────────────────────────────────────────────────────

// User Settings (one per user)
model Settings {
  id                    String  @id @default(cuid())
  userId                String  @unique // One settings record per user
  eodhdApiKey           String?
  defaultCurrency       String  @default("EUR")
  priceUpdateEnabled    Boolean @default(true)
  priceCacheDurationMin Int     @default(60)
  theme                 String  @default("system")
  locale                String  @default("es-ES")

  gmailConnected    Boolean   @default(false)
  gmailRefreshToken String?
  lastGmailImport   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
